  },
  {
    "tool": "list_devices",
    "args": {},
    "expect": {"ok": true}
  },
  {
    "tool": "select_device",
    "args": {"serial": "EMU01"},
    "expect": {"ok": true}
  },
  {
    "tool": "new_session",
    "args": {"label": "dev-loop"},
    "expect": {"ok": true}
  },
  {
    "tool": "start_debug_session",
